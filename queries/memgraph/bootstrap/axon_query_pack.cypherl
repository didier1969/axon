// Generated Axon Memgraph human query pack. Do not edit by hand.
MATCH (q:PreparedQuery) DETACH DELETE q;

MATCH (p:PreparedQueryPack) DETACH DELETE p;

CREATE (:PreparedQueryPack {id: 'axon_memgraph_query_pack', name: 'Axon Memgraph Query Pack', publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'});

UNWIND [
  {id: 'prepared_query:hot_files', name: 'hot_files', title: 'Hot Files', description: 'Largest files and graph/vector readiness by project.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (f:File)\nRETURN\n  f.project_code AS project,\n  f.path AS path,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  f.size_bytes AS size_bytes\nORDER BY coalesce(f.size_bytes, 0) DESC\nLIMIT 100;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (f:File)\nRETURN\n  f.project_code AS project,\n  f.path AS path,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  f.size_bytes AS size_bytes\nORDER BY coalesce(f.size_bytes, 0) DESC\nLIMIT 100;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'hot_files.cypher', rank: 1, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:ist_soll_traceability', name: 'ist_soll_traceability', title: 'Ist Soll Traceability', description: 'SOLL intent to evidence traceability for human inspection.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (intent)-[:TRACEABLE_TO]->(e:Evidence)\nRETURN\n  labels(intent) AS intent_labels,\n  intent.title AS intent,\n  intent.status AS status,\n  e.kind AS evidence_type,\n  e.path AS evidence_ref\nORDER BY intent, evidence_ref\nLIMIT 200;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (intent)-[:TRACEABLE_TO]->(e:Evidence)\nRETURN\n  labels(intent) AS intent_labels,\n  intent.title AS intent,\n  intent.status AS status,\n  e.kind AS evidence_type,\n  e.path AS evidence_ref\nORDER BY intent, evidence_ref\nLIMIT 200;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'ist_soll_traceability.cypher', rank: 2, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:overview', name: 'overview', title: 'Overview', description: 'Node label and relationship inventory for the active projection.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (n)\nUNWIND labels(n) AS label\nWITH label, count(n) AS node_count\nWHERE label <> \'AxonNode\'\nRETURN \'node\' AS kind, label AS type, node_count AS count\nUNION ALL\nMATCH ()-[r]->()\nRETURN \'edge\' AS kind, type(r) AS type, count(r) AS count\nORDER BY kind, type;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (n)\nUNWIND labels(n) AS label\nWITH label, count(n) AS node_count\nWHERE label <> \'AxonNode\'\nRETURN \'node\' AS kind, label AS type, node_count AS count\nUNION ALL\nMATCH ()-[r]->()\nRETURN \'edge\' AS kind, type(r) AS type, count(r) AS count\nORDER BY kind, type;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'overview.cypher', rank: 3, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:prepared_queries', name: 'prepared_queries', title: 'Prepared Queries', description: 'List the installed Axon prepared query catalog.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (q:PreparedQuery)\nRETURN\n  q.rank AS rank,\n  q.name AS name,\n  q.description AS description,\n  q.parameters AS parameters,\n  q.usage AS usage,\n  q.path AS source_file,\n  q.cypher AS cypher,\n  q.cypher_all_projects AS cypher_all_projects\nORDER BY rank, name;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (q:PreparedQuery)\nRETURN\n  q.rank AS rank,\n  q.name AS name,\n  q.description AS description,\n  q.parameters AS parameters,\n  q.usage AS usage,\n  q.path AS source_file,\n  q.cypher AS cypher,\n  q.cypher_all_projects AS cypher_all_projects\nORDER BY rank, name;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'prepared_queries.cypher', rank: 4, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:requirement_coverage', name: 'requirement_coverage', title: 'Requirement Coverage', description: 'Requirement coverage through decisions, validations, and evidence.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (r)\nWHERE \'Requirement\' IN labels(r)\nOPTIONAL MATCH (d)-[:SOLVES]->(r)\nOPTIONAL MATCH (v)-[:VERIFIES]->(r)\nOPTIONAL MATCH (r)-[:TRACEABLE_TO]->(e:Evidence)\nRETURN\n  r.title AS requirement,\n  r.status AS status,\n  count(DISTINCT d) AS solving_decisions,\n  count(DISTINCT v) AS validations,\n  count(DISTINCT e) AS evidence_items\nORDER BY validations ASC, evidence_items ASC, requirement\nLIMIT 200;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (r)\nWHERE \'Requirement\' IN labels(r)\nOPTIONAL MATCH (d)-[:SOLVES]->(r)\nOPTIONAL MATCH (v)-[:VERIFIES]->(r)\nOPTIONAL MATCH (r)-[:TRACEABLE_TO]->(e:Evidence)\nRETURN\n  r.title AS requirement,\n  r.status AS status,\n  count(DISTINCT d) AS solving_decisions,\n  count(DISTINCT v) AS validations,\n  count(DISTINCT e) AS evidence_items\nORDER BY validations ASC, evidence_items ASC, requirement\nLIMIT 200;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'requirement_coverage.cypher', rank: 5, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:soll_decisions', name: 'soll_decisions', title: 'Soll Decisions', description: 'Current SOLL decision map and outgoing intent links.', cypher: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (d)\nWHERE \'Decision\' IN labels(d)\nOPTIONAL MATCH (d)-[rel]->(target)\nRETURN\n  d.title AS decision,\n  d.status AS status,\n  collect(DISTINCT type(rel) + \' -> \' + coalesce(target.title, target.id)) AS outgoing_links\nORDER BY decision\nLIMIT 200;', cypher_all_projects: '// Copyright (c) Didier Stadelmann. All rights reserved.\n// Human-only Memgraph projection query. LLM clients must use Axon MCP.\n\nMATCH (d)\nWHERE \'Decision\' IN labels(d)\nOPTIONAL MATCH (d)-[rel]->(target)\nRETURN\n  d.title AS decision,\n  d.status AS status,\n  collect(DISTINCT type(rel) + \' -> \' + coalesce(target.title, target.id)) AS outgoing_links\nORDER BY decision\nLIMIT 200;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'soll_decisions.cypher', rank: 6, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:calls_hotspots_with_file', name: 'calls_hotspots_with_file', title: 'Calls Hotspots With File', description: 'CALLS hotspots grouped by file for dependency and blast-radius inspection.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (caller:Symbol)-[r:CALLS]->(callee:Symbol)\nWHERE project_code = \'\' OR caller.project_code = project_code OR callee.project_code = project_code\nOPTIONAL MATCH (file:File)-[:CONTAINS]->(caller)\nRETURN\n  coalesce(caller.project_code, callee.project_code, file.project_code) AS project,\n  file.path AS file,\n  caller.title AS caller,\n  count(DISTINCT callee) AS callees,\n  collect(DISTINCT callee.title)[0..20] AS sample_callees\nORDER BY callees DESC, file, caller\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (caller:Symbol)-[r:CALLS]->(callee:Symbol)\nWHERE project_code = \'\' OR caller.project_code = project_code OR callee.project_code = project_code\nOPTIONAL MATCH (file:File)-[:CONTAINS]->(caller)\nRETURN\n  coalesce(caller.project_code, callee.project_code, file.project_code) AS project,\n  file.path AS file,\n  caller.title AS caller,\n  count(DISTINCT callee) AS callees,\n  collect(DISTINCT callee.title)[0..20] AS sample_callees\nORDER BY callees DESC, file, caller\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/calls_hotspots_with_file.cypher', rank: 7, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:cross_project_links', name: 'cross_project_links', title: 'Cross Project Links', description: 'Relationships crossing project boundaries.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (a:AxonNode)-[r]->(b:AxonNode)\nWHERE a.project_code IS NOT NULL\n  AND b.project_code IS NOT NULL\n  AND a.project_code <> b.project_code\n  AND (project_code = \'\' OR a.project_code = project_code OR b.project_code = project_code)\nRETURN\n  a.project_code AS from_project,\n  b.project_code AS to_project,\n  type(r) AS relation,\n  count(r) AS count\nORDER BY count DESC, from_project, to_project\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (a:AxonNode)-[r]->(b:AxonNode)\nWHERE a.project_code IS NOT NULL\n  AND b.project_code IS NOT NULL\n  AND a.project_code <> b.project_code\n  AND (project_code = \'\' OR a.project_code = project_code OR b.project_code = project_code)\nRETURN\n  a.project_code AS from_project,\n  b.project_code AS to_project,\n  type(r) AS relation,\n  count(r) AS count\nORDER BY count DESC, from_project, to_project\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/cross_project_links.cypher', rank: 8, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:drift_readiness_signals', name: 'drift_readiness_signals', title: 'Drift Readiness Signals', description: 'Files that are graph/vector degraded and likely to distort visual analysis.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (f:File)\nWHERE project_code = \'\' OR f.project_code = project_code\nWITH\n  f.project_code AS project,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  count(*) AS files,\n  sum(coalesce(f.size_bytes, 0)) AS total_size_bytes\nRETURN\n  project,\n  status,\n  graph_ready,\n  vector_ready,\n  files,\n  total_size_bytes,\n  CASE\n    WHEN graph_ready = false AND vector_ready = false THEN \'graph_and_vector_missing\'\n    WHEN graph_ready = false THEN \'graph_missing\'\n    WHEN vector_ready = false THEN \'vector_missing\'\n    ELSE \'ready\'\n  END AS readiness_signal,\n  CASE\n    WHEN graph_ready = false AND vector_ready = false THEN 0\n    WHEN graph_ready = false THEN 1\n    WHEN vector_ready = false THEN 2\n    ELSE 3\n  END AS readiness_rank\nORDER BY\n  readiness_rank,\n  files DESC,\n  total_size_bytes DESC;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (f:File)\nWHERE project_code = \'\' OR f.project_code = project_code\nWITH\n  f.project_code AS project,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  count(*) AS files,\n  sum(coalesce(f.size_bytes, 0)) AS total_size_bytes\nRETURN\n  project,\n  status,\n  graph_ready,\n  vector_ready,\n  files,\n  total_size_bytes,\n  CASE\n    WHEN graph_ready = false AND vector_ready = false THEN \'graph_and_vector_missing\'\n    WHEN graph_ready = false THEN \'graph_missing\'\n    WHEN vector_ready = false THEN \'vector_missing\'\n    ELSE \'ready\'\n  END AS readiness_signal,\n  CASE\n    WHEN graph_ready = false AND vector_ready = false THEN 0\n    WHEN graph_ready = false THEN 1\n    WHEN vector_ready = false THEN 2\n    ELSE 3\n  END AS readiness_rank\nORDER BY\n  readiness_rank,\n  files DESC,\n  total_size_bytes DESC;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/drift_readiness_signals.cypher', rank: 9, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:evidence_inventory', name: 'evidence_inventory', title: 'Evidence Inventory', description: 'Evidence volume and linked intent coverage by project and evidence type.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (e:Evidence)\nWHERE project_code = \'\' OR e.project_code = project_code\nOPTIONAL MATCH (intent)-[:TRACEABLE_TO]->(e)\nRETURN\n  e.project_code AS project,\n  e.kind AS evidence_type,\n  count(DISTINCT e) AS evidence_items,\n  count(DISTINCT intent) AS linked_intents\nORDER BY project, evidence_items DESC, evidence_type;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (e:Evidence)\nWHERE project_code = \'\' OR e.project_code = project_code\nOPTIONAL MATCH (intent)-[:TRACEABLE_TO]->(e)\nRETURN\n  e.project_code AS project,\n  e.kind AS evidence_type,\n  count(DISTINCT e) AS evidence_items,\n  count(DISTINCT intent) AS linked_intents\nORDER BY project, evidence_items DESC, evidence_type;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/evidence_inventory.cypher', rank: 10, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:files_by_readiness', name: 'files_by_readiness', title: 'Files By Readiness', description: 'File readiness distribution for graph and vector lanes.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (f:File)\nWHERE project_code = \'\' OR f.project_code = project_code\nRETURN\n  f.project_code AS project,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  count(*) AS files,\n  sum(coalesce(f.size_bytes, 0)) AS total_size_bytes\nORDER BY project, files DESC;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (f:File)\nWHERE project_code = \'\' OR f.project_code = project_code\nRETURN\n  f.project_code AS project,\n  f.status AS status,\n  f.graph_ready AS graph_ready,\n  f.vector_ready AS vector_ready,\n  count(*) AS files,\n  sum(coalesce(f.size_bytes, 0)) AS total_size_bytes\nORDER BY project, files DESC;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/files_by_readiness.cypher', rank: 11, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:high_degree_nodes', name: 'high_degree_nodes', title: 'High Degree Nodes', description: 'High-degree graph nodes that dominate topology or may indicate modeling noise.', cypher: '// Parameters: project_code optional, min_degree optional. Use "" or null for all projects.\nWITH\n  coalesce($project_code, \'\') AS project_code,\n  coalesce($min_degree, 25) AS min_degree\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nOPTIONAL MATCH (n)-[out]->()\nWITH project_code, min_degree, n, count(DISTINCT out) AS outgoing_edges\nOPTIONAL MATCH ()-[in]->(n)\nWITH n, outgoing_edges, count(DISTINCT in) AS incoming_edges, min_degree\nWITH n, labels(n) AS node_labels, incoming_edges, outgoing_edges, incoming_edges + outgoing_edges AS total_degree, min_degree\nWHERE total_degree >= min_degree\nRETURN\n  n.project_code AS project,\n  node_labels AS labels,\n  coalesce(n.title, n.path, n.id) AS node,\n  incoming_edges,\n  outgoing_edges,\n  total_degree\nORDER BY total_degree DESC, incoming_edges DESC, outgoing_edges DESC\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional, min_degree optional. Use "" or null for all projects.\nWITH\n  coalesce(\'\', \'\') AS project_code,\n  coalesce(25, 25) AS min_degree\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nOPTIONAL MATCH (n)-[out]->()\nWITH project_code, min_degree, n, count(DISTINCT out) AS outgoing_edges\nOPTIONAL MATCH ()-[in]->(n)\nWITH n, outgoing_edges, count(DISTINCT in) AS incoming_edges, min_degree\nWITH n, labels(n) AS node_labels, incoming_edges, outgoing_edges, incoming_edges + outgoing_edges AS total_degree, min_degree\nWHERE total_degree >= min_degree\nRETURN\n  n.project_code AS project,\n  node_labels AS labels,\n  coalesce(n.title, n.path, n.id) AS node,\n  incoming_edges,\n  outgoing_edges,\n  total_degree\nORDER BY total_degree DESC, incoming_edges DESC, outgoing_edges DESC\nLIMIT 300;', parameters: '{"min_degree": "optional integer; default is query-specific", "project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/high_degree_nodes.cypher', rank: 12, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:ist_hot_symbols', name: 'ist_hot_symbols', title: 'Ist Hot Symbols', description: 'Most connected IST symbols by incoming and outgoing graph degree.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (s:Symbol)\nWHERE project_code = \'\' OR s.project_code = project_code\nOPTIONAL MATCH (s)-[out]->()\nOPTIONAL MATCH ()-[in]->(s)\nRETURN\n  s.project_code AS project,\n  s.title AS symbol,\n  s.kind AS kind,\n  count(DISTINCT out) AS outgoing_edges,\n  count(DISTINCT in) AS incoming_edges,\n  count(DISTINCT out) + count(DISTINCT in) AS total_degree\nORDER BY total_degree DESC, incoming_edges DESC, outgoing_edges DESC\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (s:Symbol)\nWHERE project_code = \'\' OR s.project_code = project_code\nOPTIONAL MATCH (s)-[out]->()\nOPTIONAL MATCH ()-[in]->(s)\nRETURN\n  s.project_code AS project,\n  s.title AS symbol,\n  s.kind AS kind,\n  count(DISTINCT out) AS outgoing_edges,\n  count(DISTINCT in) AS incoming_edges,\n  count(DISTINCT out) + count(DISTINCT in) AS total_degree\nORDER BY total_degree DESC, incoming_edges DESC, outgoing_edges DESC\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/ist_hot_symbols.cypher', rank: 13, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:ist_orphan_symbols', name: 'ist_orphan_symbols', title: 'Ist Orphan Symbols', description: 'IST symbols with no graph relationships.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (s:Symbol)\nWHERE project_code = \'\' OR s.project_code = project_code\nOPTIONAL MATCH (s)-[r]-()\nWITH s, count(DISTINCT r) AS degree\nWHERE degree = 0\nRETURN\n  s.project_code AS project,\n  s.title AS symbol,\n  s.kind AS kind,\n  s.status AS status,\n  degree\nORDER BY project, symbol\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (s:Symbol)\nWHERE project_code = \'\' OR s.project_code = project_code\nOPTIONAL MATCH (s)-[r]-()\nWITH s, count(DISTINCT r) AS degree\nWHERE degree = 0\nRETURN\n  s.project_code AS project,\n  s.title AS symbol,\n  s.kind AS kind,\n  s.status AS status,\n  degree\nORDER BY project, symbol\nLIMIT 300;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/ist_orphan_symbols.cypher', rank: 14, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:orphan_soll_nodes', name: 'orphan_soll_nodes', title: 'Orphan Soll Nodes', description: 'SOLL requirements, decisions, and validations that are isolated from the intent graph.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (n:AxonNode)\nWITH project_code, n, labels(n) AS node_labels\nWHERE (project_code = \'\' OR n.project_code = project_code)\n  AND (\'Requirement\' IN node_labels OR \'Decision\' IN node_labels OR \'Validation\' IN node_labels)\nOPTIONAL MATCH (n)-[r]-()\nWITH n, node_labels, count(DISTINCT r) AS degree\nWHERE degree = 0\nRETURN\n  n.project_code AS project,\n  node_labels AS labels,\n  n.title AS node,\n  n.status AS status,\n  n.id AS id,\n  degree\nORDER BY project, labels, node\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (n:AxonNode)\nWITH project_code, n, labels(n) AS node_labels\nWHERE (project_code = \'\' OR n.project_code = project_code)\n  AND (\'Requirement\' IN node_labels OR \'Decision\' IN node_labels OR \'Validation\' IN node_labels)\nOPTIONAL MATCH (n)-[r]-()\nWITH n, node_labels, count(DISTINCT r) AS degree\nWHERE degree = 0\nRETURN\n  n.project_code AS project,\n  node_labels AS labels,\n  n.title AS node,\n  n.status AS status,\n  n.id AS id,\n  degree\nORDER BY project, labels, node\nLIMIT 300;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/orphan_soll_nodes.cypher', rank: 15, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:project_code_inventory', name: 'project_code_inventory', title: 'Project Code Inventory', description: 'Available project codes with label-scoped node counts.', cypher: '// Parameters: none.\nMATCH (n:AxonNode)\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS node_labels\nRETURN\n  project,\n  count(*) AS nodes,\n  sum(CASE WHEN \'File\' IN node_labels THEN 1 ELSE 0 END) AS files,\n  sum(CASE WHEN \'Symbol\' IN node_labels THEN 1 ELSE 0 END) AS symbols,\n  sum(CASE WHEN \'Requirement\' IN node_labels THEN 1 ELSE 0 END) AS requirements,\n  sum(CASE WHEN \'Decision\' IN node_labels THEN 1 ELSE 0 END) AS decisions,\n  sum(CASE WHEN \'Validation\' IN node_labels THEN 1 ELSE 0 END) AS validations,\n  sum(CASE WHEN \'Evidence\' IN node_labels THEN 1 ELSE 0 END) AS evidence,\n  sum(CASE WHEN \'UnresolvedEndpoint\' IN node_labels THEN 1 ELSE 0 END) AS unresolved_endpoints\nORDER BY nodes DESC, project;', cypher_all_projects: '// Parameters: none.\nMATCH (n:AxonNode)\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS node_labels\nRETURN\n  project,\n  count(*) AS nodes,\n  sum(CASE WHEN \'File\' IN node_labels THEN 1 ELSE 0 END) AS files,\n  sum(CASE WHEN \'Symbol\' IN node_labels THEN 1 ELSE 0 END) AS symbols,\n  sum(CASE WHEN \'Requirement\' IN node_labels THEN 1 ELSE 0 END) AS requirements,\n  sum(CASE WHEN \'Decision\' IN node_labels THEN 1 ELSE 0 END) AS decisions,\n  sum(CASE WHEN \'Validation\' IN node_labels THEN 1 ELSE 0 END) AS validations,\n  sum(CASE WHEN \'Evidence\' IN node_labels THEN 1 ELSE 0 END) AS evidence,\n  sum(CASE WHEN \'UnresolvedEndpoint\' IN node_labels THEN 1 ELSE 0 END) AS unresolved_endpoints\nORDER BY nodes DESC, project;', parameters: '{}', usage: 'Memgraph Lab: run cypher directly.', path: 'catalog/project_code_inventory.cypher', rank: 16, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:project_dashboard', name: 'project_dashboard', title: 'Project Dashboard', description: 'Per-project node inventory across IST and SOLL labels.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS labels\nUNWIND labels AS label\nWITH project, label, count(*) AS count\nWHERE label <> \'AxonNode\'\nRETURN project, label, count\nORDER BY project, count DESC, label;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS labels\nUNWIND labels AS label\nWITH project, label, count(*) AS count\nWHERE label <> \'AxonNode\'\nRETURN project, label, count\nORDER BY project, count DESC, label;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/project_dashboard.cypher', rank: 17, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:project_entry_points', name: 'project_entry_points', title: 'Project Entry Points', description: 'Files with many symbols and graph connections, useful as human entry points.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (f:File)-[:CONTAINS]->(s:Symbol)\nWHERE project_code = \'\' OR f.project_code = project_code OR s.project_code = project_code\nWITH f, count(s) AS symbols\nOPTIONAL MATCH (f)-[r]-()\nRETURN\n  f.project_code AS project,\n  f.path AS file,\n  f.status AS status,\n  symbols,\n  count(DISTINCT r) AS graph_degree,\n  f.size_bytes AS size_bytes\nORDER BY graph_degree DESC, symbols DESC, size_bytes DESC\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (f:File)-[:CONTAINS]->(s:Symbol)\nWHERE project_code = \'\' OR f.project_code = project_code OR s.project_code = project_code\nWITH f, count(s) AS symbols\nOPTIONAL MATCH (f)-[r]-()\nRETURN\n  f.project_code AS project,\n  f.path AS file,\n  f.status AS status,\n  symbols,\n  count(DISTINCT r) AS graph_degree,\n  f.size_bytes AS size_bytes\nORDER BY graph_degree DESC, symbols DESC, size_bytes DESC\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/project_entry_points.cypher', rank: 18, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:project_health_scoreboard', name: 'project_health_scoreboard', title: 'Project Health Scoreboard', description: 'Project-level graph health scoreboard for files, symbols, intent, evidence, and unresolved endpoints.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS node_labels, n\nRETURN\n  project,\n  count(*) AS total_nodes,\n  sum(CASE WHEN \'File\' IN node_labels THEN 1 ELSE 0 END) AS files,\n  sum(CASE WHEN \'Symbol\' IN node_labels THEN 1 ELSE 0 END) AS symbols,\n  sum(CASE WHEN \'Requirement\' IN node_labels THEN 1 ELSE 0 END) AS requirements,\n  sum(CASE WHEN \'Decision\' IN node_labels THEN 1 ELSE 0 END) AS decisions,\n  sum(CASE WHEN \'Validation\' IN node_labels THEN 1 ELSE 0 END) AS validations,\n  sum(CASE WHEN \'Evidence\' IN node_labels THEN 1 ELSE 0 END) AS evidence,\n  sum(CASE WHEN \'UnresolvedEndpoint\' IN node_labels THEN 1 ELSE 0 END) AS unresolved_endpoints,\n  sum(CASE WHEN n.graph_ready = true THEN 1 ELSE 0 END) AS graph_ready_files,\n  sum(CASE WHEN n.vector_ready = true THEN 1 ELSE 0 END) AS vector_ready_files\nORDER BY total_nodes DESC, project;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (n:AxonNode)\nWHERE project_code = \'\' OR n.project_code = project_code\nWITH coalesce(n.project_code, \'unknown\') AS project, labels(n) AS node_labels, n\nRETURN\n  project,\n  count(*) AS total_nodes,\n  sum(CASE WHEN \'File\' IN node_labels THEN 1 ELSE 0 END) AS files,\n  sum(CASE WHEN \'Symbol\' IN node_labels THEN 1 ELSE 0 END) AS symbols,\n  sum(CASE WHEN \'Requirement\' IN node_labels THEN 1 ELSE 0 END) AS requirements,\n  sum(CASE WHEN \'Decision\' IN node_labels THEN 1 ELSE 0 END) AS decisions,\n  sum(CASE WHEN \'Validation\' IN node_labels THEN 1 ELSE 0 END) AS validations,\n  sum(CASE WHEN \'Evidence\' IN node_labels THEN 1 ELSE 0 END) AS evidence,\n  sum(CASE WHEN \'UnresolvedEndpoint\' IN node_labels THEN 1 ELSE 0 END) AS unresolved_endpoints,\n  sum(CASE WHEN n.graph_ready = true THEN 1 ELSE 0 END) AS graph_ready_files,\n  sum(CASE WHEN n.vector_ready = true THEN 1 ELSE 0 END) AS vector_ready_files\nORDER BY total_nodes DESC, project;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/project_health_scoreboard.cypher', rank: 19, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:project_relationships', name: 'project_relationships', title: 'Project Relationships', description: 'Relationship inventory by project.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (a:AxonNode)-[r]->(b:AxonNode)\nWHERE project_code = \'\' OR a.project_code = project_code OR b.project_code = project_code\nRETURN\n  coalesce(a.project_code, b.project_code, \'unknown\') AS project,\n  type(r) AS relation,\n  count(r) AS count\nORDER BY project, count DESC, relation;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (a:AxonNode)-[r]->(b:AxonNode)\nWHERE project_code = \'\' OR a.project_code = project_code OR b.project_code = project_code\nRETURN\n  coalesce(a.project_code, b.project_code, \'unknown\') AS project,\n  type(r) AS relation,\n  count(r) AS count\nORDER BY project, count DESC, relation;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/project_relationships.cypher', rank: 20, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:soll_decision_impact', name: 'soll_decision_impact', title: 'Soll Decision Impact', description: 'SOLL decisions and nearby affected intent nodes.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (d:Decision)\nWHERE project_code = \'\' OR d.project_code = project_code\nOPTIONAL MATCH p=(d)-[*1..2]->(target:AxonNode)\nRETURN\n  d.project_code AS project,\n  d.title AS decision,\n  d.status AS status,\n  count(DISTINCT target) AS reachable_intent_nodes,\n  collect(DISTINCT coalesce(target.title, target.id))[0..20] AS sample_targets\nORDER BY reachable_intent_nodes DESC, decision\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (d:Decision)\nWHERE project_code = \'\' OR d.project_code = project_code\nOPTIONAL MATCH p=(d)-[*1..2]->(target:AxonNode)\nRETURN\n  d.project_code AS project,\n  d.title AS decision,\n  d.status AS status,\n  count(DISTINCT target) AS reachable_intent_nodes,\n  collect(DISTINCT coalesce(target.title, target.id))[0..20] AS sample_targets\nORDER BY reachable_intent_nodes DESC, decision\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/soll_decision_impact.cypher', rank: 21, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:soll_requirement_risk', name: 'soll_requirement_risk', title: 'Soll Requirement Risk', description: 'Requirements missing decisions, validations, or evidence.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (r:Requirement)\nWHERE project_code = \'\' OR r.project_code = project_code\nOPTIONAL MATCH (d)-[:SOLVES]->(r)\nOPTIONAL MATCH (v)-[:VERIFIES]->(r)\nOPTIONAL MATCH (r)-[:TRACEABLE_TO]->(e)\nWITH\n  r,\n  count(DISTINCT d) AS decisions,\n  count(DISTINCT v) AS validations,\n  count(DISTINCT e) AS evidence\nRETURN\n  r.project_code AS project,\n  r.title AS requirement,\n  r.status AS status,\n  decisions,\n  validations,\n  evidence,\n  CASE\n    WHEN validations = 0 THEN \'missing_validation\'\n    WHEN evidence = 0 THEN \'missing_evidence\'\n    WHEN decisions = 0 THEN \'missing_decision\'\n    ELSE \'covered\'\n  END AS risk\nORDER BY risk DESC, validations ASC, evidence ASC, requirement\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (r:Requirement)\nWHERE project_code = \'\' OR r.project_code = project_code\nOPTIONAL MATCH (d)-[:SOLVES]->(r)\nOPTIONAL MATCH (v)-[:VERIFIES]->(r)\nOPTIONAL MATCH (r)-[:TRACEABLE_TO]->(e)\nWITH\n  r,\n  count(DISTINCT d) AS decisions,\n  count(DISTINCT v) AS validations,\n  count(DISTINCT e) AS evidence\nRETURN\n  r.project_code AS project,\n  r.title AS requirement,\n  r.status AS status,\n  decisions,\n  validations,\n  evidence,\n  CASE\n    WHEN validations = 0 THEN \'missing_validation\'\n    WHEN evidence = 0 THEN \'missing_evidence\'\n    WHEN decisions = 0 THEN \'missing_decision\'\n    ELSE \'covered\'\n  END AS risk\nORDER BY risk DESC, validations ASC, evidence ASC, requirement\nLIMIT 300;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/soll_requirement_risk.cypher', rank: 22, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:top_evidence_references', name: 'top_evidence_references', title: 'Top Evidence References', description: 'Evidence nodes most referenced by SOLL intent.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (intent:AxonNode)-[:TRACEABLE_TO]->(e:Evidence)\nWHERE project_code = \'\' OR intent.project_code = project_code OR e.project_code = project_code\nRETURN\n  coalesce(e.project_code, intent.project_code) AS project,\n  coalesce(e.title, e.path, e.id) AS evidence,\n  e.kind AS evidence_type,\n  count(DISTINCT intent) AS linked_intents,\n  collect(DISTINCT coalesce(intent.title, intent.id))[0..20] AS sample_intents\nORDER BY linked_intents DESC, project, evidence\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (intent:AxonNode)-[:TRACEABLE_TO]->(e:Evidence)\nWHERE project_code = \'\' OR intent.project_code = project_code OR e.project_code = project_code\nRETURN\n  coalesce(e.project_code, intent.project_code) AS project,\n  coalesce(e.title, e.path, e.id) AS evidence,\n  e.kind AS evidence_type,\n  count(DISTINCT intent) AS linked_intents,\n  collect(DISTINCT coalesce(intent.title, intent.id))[0..20] AS sample_intents\nORDER BY linked_intents DESC, project, evidence\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/top_evidence_references.cypher', rank: 23, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:trace_target_context', name: 'trace_target_context', title: 'Trace Target Context', description: 'Targeted 1-hop/2-hop context around an id, path, title, or symbol fragment.', cypher: '// Parameters: target required as id/path/title/symbol fragment, project_code optional.\nWITH\n  coalesce($project_code, \'\') AS project_code,\n  coalesce($target, \'\') AS target\nMATCH (n:AxonNode)\nWHERE target <> \'\'\n  AND (project_code = \'\' OR n.project_code = project_code)\n  AND (\n    n.id = target\n    OR n.path = target\n    OR n.title = target\n    OR n.name = target\n    OR n.symbol = target\n    OR n.id CONTAINS target\n    OR n.path CONTAINS target\n    OR n.title CONTAINS target\n  )\nOPTIONAL MATCH (n)-[r1]-(one:AxonNode)\nOPTIONAL MATCH (one)-[r2]-(two:AxonNode)\nRETURN\n  n.project_code AS project,\n  labels(n) AS target_labels,\n  coalesce(n.title, n.path, n.id) AS target_node,\n  count(DISTINCT one) AS one_hop_neighbors,\n  count(DISTINCT two) AS two_hop_neighbors,\n  collect(DISTINCT type(r1))[0..20] AS one_hop_relations,\n  collect(DISTINCT coalesce(one.title, one.path, one.id))[0..30] AS sample_one_hop,\n  collect(DISTINCT coalesce(two.title, two.path, two.id))[0..30] AS sample_two_hop\nORDER BY one_hop_neighbors DESC, two_hop_neighbors DESC\nLIMIT 50;', cypher_all_projects: '// Parameters: target required as id/path/title/symbol fragment, project_code optional.\nWITH\n  coalesce(\'\', \'\') AS project_code,\n  coalesce($target, \'\') AS target\nMATCH (n:AxonNode)\nWHERE target <> \'\'\n  AND (project_code = \'\' OR n.project_code = project_code)\n  AND (\n    n.id = target\n    OR n.path = target\n    OR n.title = target\n    OR n.name = target\n    OR n.symbol = target\n    OR n.id CONTAINS target\n    OR n.path CONTAINS target\n    OR n.title CONTAINS target\n  )\nOPTIONAL MATCH (n)-[r1]-(one:AxonNode)\nOPTIONAL MATCH (one)-[r2]-(two:AxonNode)\nRETURN\n  n.project_code AS project,\n  labels(n) AS target_labels,\n  coalesce(n.title, n.path, n.id) AS target_node,\n  count(DISTINCT one) AS one_hop_neighbors,\n  count(DISTINCT two) AS two_hop_neighbors,\n  collect(DISTINCT type(r1))[0..20] AS one_hop_relations,\n  collect(DISTINCT coalesce(one.title, one.path, one.id))[0..30] AS sample_one_hop,\n  collect(DISTINCT coalesce(two.title, two.path, two.id))[0..30] AS sample_two_hop\nORDER BY one_hop_neighbors DESC, two_hop_neighbors DESC\nLIMIT 50;', parameters: '{"project_code": "optional string; empty or null means all projects", "target": "required string; id, path, title, name, or symbol fragment"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually. Set target when required. If target is required and parameters are unavailable, replace $target manually.', path: 'catalog/trace_target_context.cypher', rank: 24, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:traceability_gaps', name: 'traceability_gaps', title: 'Traceability Gaps', description: 'SOLL intent nodes without evidence traceability.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (n:AxonNode)\nWITH project_code, n, labels(n) AS node_labels\nWHERE (project_code = \'\' OR n.project_code = project_code)\n  AND (\'Requirement\' IN node_labels OR \'Decision\' IN node_labels OR \'Validation\' IN node_labels)\nOPTIONAL MATCH (n)-[:TRACEABLE_TO]->(e)\nWITH n, node_labels, count(DISTINCT e) AS evidence\nWHERE evidence = 0\nWITH\n  n,\n  CASE\n    WHEN \'Requirement\' IN node_labels THEN \'Requirement\'\n    WHEN \'Decision\' IN node_labels THEN \'Decision\'\n    WHEN \'Validation\' IN node_labels THEN \'Validation\'\n    ELSE \'Intent\'\n  END AS intent_label,\n  evidence\nRETURN\n  n.project_code AS project,\n  intent_label AS label,\n  n.title AS intent,\n  n.status AS status,\n  evidence\nORDER BY project, label, intent\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (n:AxonNode)\nWITH project_code, n, labels(n) AS node_labels\nWHERE (project_code = \'\' OR n.project_code = project_code)\n  AND (\'Requirement\' IN node_labels OR \'Decision\' IN node_labels OR \'Validation\' IN node_labels)\nOPTIONAL MATCH (n)-[:TRACEABLE_TO]->(e)\nWITH n, node_labels, count(DISTINCT e) AS evidence\nWHERE evidence = 0\nWITH\n  n,\n  CASE\n    WHEN \'Requirement\' IN node_labels THEN \'Requirement\'\n    WHEN \'Decision\' IN node_labels THEN \'Decision\'\n    WHEN \'Validation\' IN node_labels THEN \'Validation\'\n    ELSE \'Intent\'\n  END AS intent_label,\n  evidence\nRETURN\n  n.project_code AS project,\n  intent_label AS label,\n  n.title AS intent,\n  n.status AS status,\n  evidence\nORDER BY project, label, intent\nLIMIT 300;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/traceability_gaps.cypher', rank: 25, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:unresolved_endpoints', name: 'unresolved_endpoints', title: 'Unresolved Endpoints', description: 'Referenced graph endpoints that were not materialized as canonical nodes.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (u:UnresolvedEndpoint)\nWHERE project_code = \'\' OR u.project_code = project_code\nOPTIONAL MATCH (u)-[out]->()\nOPTIONAL MATCH ()-[in]->(u)\nRETURN\n  u.project_code AS project,\n  u.id AS endpoint,\n  count(DISTINCT in) AS incoming_edges,\n  count(DISTINCT out) AS outgoing_edges,\n  count(DISTINCT in) + count(DISTINCT out) AS total_degree\nORDER BY total_degree DESC, incoming_edges DESC\nLIMIT 300;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (u:UnresolvedEndpoint)\nWHERE project_code = \'\' OR u.project_code = project_code\nOPTIONAL MATCH (u)-[out]->()\nOPTIONAL MATCH ()-[in]->(u)\nRETURN\n  u.project_code AS project,\n  u.id AS endpoint,\n  count(DISTINCT in) AS incoming_edges,\n  count(DISTINCT out) AS outgoing_edges,\n  count(DISTINCT in) + count(DISTINCT out) AS total_degree\nORDER BY total_degree DESC, incoming_edges DESC\nLIMIT 300;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/unresolved_endpoints.cypher', rank: 26, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'},
  {id: 'prepared_query:why_unresolved_endpoint', name: 'why_unresolved_endpoint', title: 'Why Unresolved Endpoint', description: 'Explain unresolved endpoints through connected source nodes and relation types.', cypher: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce($project_code, \'\') AS project_code\nMATCH (u:UnresolvedEndpoint)\nWHERE project_code = \'\' OR u.project_code = project_code\nOPTIONAL MATCH (source:AxonNode)-[incoming]->(u)\nOPTIONAL MATCH (u)-[outgoing]->(target:AxonNode)\nRETURN\n  u.project_code AS project,\n  u.id AS unresolved_endpoint,\n  count(DISTINCT incoming) AS incoming_edges,\n  count(DISTINCT outgoing) AS outgoing_edges,\n  collect(DISTINCT type(incoming))[0..20] AS incoming_relations,\n  collect(DISTINCT type(outgoing))[0..20] AS outgoing_relations,\n  collect(DISTINCT coalesce(source.title, source.path, source.id))[0..20] AS sample_sources,\n  collect(DISTINCT coalesce(target.title, target.path, target.id))[0..20] AS sample_targets\nORDER BY incoming_edges DESC, outgoing_edges DESC, unresolved_endpoint\nLIMIT 200;', cypher_all_projects: '// Parameters: project_code optional. Use "" or null for all projects.\nWITH coalesce(\'\', \'\') AS project_code\nMATCH (u:UnresolvedEndpoint)\nWHERE project_code = \'\' OR u.project_code = project_code\nOPTIONAL MATCH (source:AxonNode)-[incoming]->(u)\nOPTIONAL MATCH (u)-[outgoing]->(target:AxonNode)\nRETURN\n  u.project_code AS project,\n  u.id AS unresolved_endpoint,\n  count(DISTINCT incoming) AS incoming_edges,\n  count(DISTINCT outgoing) AS outgoing_edges,\n  collect(DISTINCT type(incoming))[0..20] AS incoming_relations,\n  collect(DISTINCT type(outgoing))[0..20] AS outgoing_relations,\n  collect(DISTINCT coalesce(source.title, source.path, source.id))[0..20] AS sample_sources,\n  collect(DISTINCT coalesce(target.title, target.path, target.id))[0..20] AS sample_targets\nORDER BY incoming_edges DESC, outgoing_edges DESC, unresolved_endpoint\nLIMIT 200;', parameters: '{"project_code": "optional string; empty or null means all projects"}', usage: 'Memgraph Lab: set parameter project_code to a project code, or empty/null for all projects. If Lab parameters are unavailable, run cypher_all_projects directly or replace $project_code manually.', path: 'catalog/why_unresolved_endpoint.cypher', rank: 27, publication_id: 'standalone', human_only: true, llm_contract: 'use_axon_mcp_not_memgraph'}
]
AS row CREATE (q:PreparedQuery) SET q += row;

MATCH (p:PreparedQueryPack {id: 'axon_memgraph_query_pack'}), (q:PreparedQuery) CREATE (p)-[:HAS_PREPARED_QUERY]->(q);

MATCH (q:PreparedQuery) RETURN count(q) AS installed_prepared_queries;
