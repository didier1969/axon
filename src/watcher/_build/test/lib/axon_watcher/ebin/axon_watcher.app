{application,axon_watcher,
             [{modules,['Elixir.Axon.Scanner',
                        'Elixir.Axon.Watcher.Application',
                        'Elixir.Axon.Watcher.PoolFacade',
                        'Elixir.Axon.Watcher.Progress',
                        'Elixir.Axon.Watcher.Server',
                        'Elixir.Axon.Watcher.Worker']},
              {compile_env,[{axon_watcher,['Elixir.Axon.Scanner'],error}]},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,rustler,jason,msgpax,
                             nimble_pool,file_system]},
              {description,"axon_watcher"},
              {registered,[]},
              {vsn,"1.0.0"},
              {mod,{'Elixir.Axon.Watcher.Application',[]}}]}.
