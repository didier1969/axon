{application,axon_watcher,
    [{modules,
         ['Elixir.Axon.Scanner','Elixir.Axon.Watcher.Application',
          'Elixir.Axon.Watcher.CockpitLive','Elixir.Axon.Watcher.Endpoint',
          'Elixir.Axon.Watcher.FaviconController',
          'Elixir.Axon.Watcher.IndexingWorker','Elixir.Axon.Watcher.Layouts',
          'Elixir.Axon.Watcher.Progress','Elixir.Axon.Watcher.Repo',
          'Elixir.Axon.Watcher.Router','Elixir.Axon.Watcher.Router.Helpers',
          'Elixir.Axon.Watcher.Schemas.ExtractionResult',
          'Elixir.Axon.Watcher.Schemas.Relationship',
          'Elixir.Axon.Watcher.Schemas.Symbol','Elixir.Axon.Watcher.Server',
          'Elixir.Axon.Watcher.Telemetry']},
     {compile_env,
         [{axon_watcher,['Elixir.Axon.Scanner'],error},
          {axon_watcher,['Elixir.Axon.Watcher.Endpoint',code_reloader],error},
          {axon_watcher,['Elixir.Axon.Watcher.Endpoint',debug_errors],error},
          {axon_watcher,['Elixir.Axon.Watcher.Endpoint',force_ssl],error}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,rustler,jason,msgpax,nimble_pool,
          file_system,phoenix,phoenix_live_view,bandit,ecto,ecto_sqlite3,
          oban]},
     {description,"axon_watcher"},
     {registered,[]},
     {vsn,"1.0.0"},
     {mod,{'Elixir.Axon.Watcher.Application',[]}}]}.
