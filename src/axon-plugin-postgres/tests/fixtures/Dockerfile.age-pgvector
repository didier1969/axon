# MIL-AXO-015 P4 slice 4b — combined AGE + pgvector test image.
#
# Both extensions are required by the full per-project schema:
#   - Apache AGE provides `cypher()` + `agtype` for graph queries
#     (CPT-AXO-040).
#   - pgvector provides `vector(N)` + HNSW for ChunkEmbedding ANN
#     (CPT-AXO-041).
# `apache/age:release_PG17_1.6.0` ships AGE preinstalled but lacks
# pgvector; this image adds pgvector on top so integration tests can
# exercise the entire DDL generator and the vector lane round-trip
# without splitting fixtures.
#
# Build (run once locally; testcontainers references the resulting tag):
#   docker build \
#     -t axon-test/age-pgvector:pg17 \
#     -f src/axon-plugin-postgres/tests/fixtures/Dockerfile.age-pgvector \
#     src/axon-plugin-postgres/tests/fixtures
#
# Then `cargo test --test integration_pg --test ffi_contract --
# --ignored` will pick the local image automatically once the
# integration tests are switched to it (slice 4b follow-up).

FROM apache/age:release_PG17_1.6.0

USER root

# Postgres 17 client + build deps for pgvector. Use BuildKit cache
# directives where available; here we keep it portable.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
         ca-certificates \
         build-essential \
         git \
         postgresql-server-dev-17 \
    && rm -rf /var/lib/apt/lists/*

# Pin pgvector to the latest stable release that's been validated
# against PG 17. Bump deliberately when we want to test against newer
# pgvector versions; do not float to `master`.
ARG PGVECTOR_REF=v0.8.0
RUN git clone --branch ${PGVECTOR_REF} --depth 1 https://github.com/pgvector/pgvector.git /tmp/pgvector \
    && cd /tmp/pgvector \
    && make \
    && make install \
    && rm -rf /tmp/pgvector

USER postgres
