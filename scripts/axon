#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage: ./scripts/axon <command> [options]

Commands:
  setup                    Bootstrap environment and build artifacts
  start [mode options]     Start runtime (supports --full|--graph-only|--read-only|--mcp-only|--no-dashboard)
  stop [options]           Stop runtime (supports --hard|--verify)
  restart [mode options]   Stop then start
  status                   Runtime health/status check
  qualify [args...]        Run unified qualification pipeline
  validate-mcp [args...]   Exhaustive MCP tool validation
  robustness-mcp [args...] Qualify MCP responsiveness and recovery under load
  quality-mcp              Run strict MCP quality gate on core projects
  soll-import [args...]    Bulk import SOLL payloads via MCP (md/json/ndjson/yaml)
  work-plan [args...]      Generate an ideal read-only work plan from SOLL
  resume-vectorization [args...] Requeue missing chunk vectorization from graph-ready files
  migrate-ignore [args...] Migrate .axonignore patterns to .gitignore (dry-run by default)
  reindex-project [args...] Reindex one project with before/after noise evaluation

Examples:
  ./scripts/axon setup
  ./scripts/axon start --full
  ./scripts/axon start --graph-only
  ./scripts/axon stop --hard
  ./scripts/axon restart --read-only
  ./scripts/axon status
  ./scripts/axon qualify --profile demo --mode graph_only
  ./scripts/axon qualify --profile full --mode full --duration 120 --interval 5 --enforce-gate
  ./scripts/axon qualify --profile smoke --compare mcp_only,graph_only
  ./scripts/axon validate-mcp --project BookingSystem --strict
  ./scripts/axon robustness-mcp --modes mcp_only,full --duration 60 --concurrency 4
  ./scripts/axon quality-mcp
  ./scripts/axon soll-import --input docs/vision/SOLL_EXPORT_2026-04-04.md --format md
  ./scripts/axon soll-import --input /tmp/soll_payload.json --project AXO --author codex --dry-run
  ./scripts/axon work-plan --project AXO
  ./scripts/axon work-plan --project AXO --json
  ./scripts/axon resume-vectorization
  ./scripts/axon migrate-ignore --root /home/dstadel/projects --apply
  ./scripts/axon reindex-project --project BookingSystem --wait-seconds 180
USAGE
}

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
  usage
  exit 1
fi
shift || true

case "$cmd" in
  setup)
    exec bash "$SCRIPT_DIR/setup.sh" "$@"
    ;;
  start)
    exec bash "$SCRIPT_DIR/start.sh" "$@"
    ;;
  stop)
    exec bash "$SCRIPT_DIR/stop.sh" "$@"
    ;;
  restart)
    bash "$SCRIPT_DIR/stop.sh" "$@"
    exec bash "$SCRIPT_DIR/start.sh" "$@"
    ;;
  status)
    exec bash "$SCRIPT_DIR/status.sh" "$@"
    ;;
  qualify)
    exec python3 "$SCRIPT_DIR/qualify_runtime.py" "$@"
    ;;
  validate-mcp)
    exec python3 "$SCRIPT_DIR/mcp_validate.py" "$@"
    ;;
  robustness-mcp)
    exec python3 "$SCRIPT_DIR/qualify_mcp_robustness.py" "$@"
    ;;
  quality-mcp)
    exec bash "$SCRIPT_DIR/mcp_quality_gate.sh"
    ;;
  soll-import)
    exec python3 "$SCRIPT_DIR/soll_import.py" "$@"
    ;;
  work-plan)
    exec python3 "$SCRIPT_DIR/work_plan.py" "$@"
    ;;
  resume-vectorization)
    exec python3 "$SCRIPT_DIR/resume_vectorization.py" "$@"
    ;;
  migrate-ignore)
    exec bash "$SCRIPT_DIR/migrate_axonignore_to_gitignore.sh" "$@"
    ;;
  reindex-project)
    exec python3 "$SCRIPT_DIR/reindex_project.py" "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
