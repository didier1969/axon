#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck source=scripts/lib/axon-instance.sh
source "$SCRIPT_DIR/lib/axon-instance.sh"

usage() {
  cat <<'USAGE'
Usage: ./scripts/axon [--instance live|dev] <command> [options]

Commands:
  setup                    Bootstrap environment and build artifacts
  setup-tensorrt           Build/validate the local TensorRT ORT artifact, optionally qualify it
  start [mode options]     Start runtime (supports --brain-only|--indexer-graph|--indexer-vector|--indexer-full|--no-dashboard)
  stop [options]           Stop runtime (supports --role brain|indexer|all, --hard, --verify)
  restart [mode options]   Stop then start
  status                   Runtime health/status check
  qualify [args...]        Unified qualification pipeline (defaults to dev). Supports --cold, --tensorrt, --build-tensorrt-from-tarball
  qualify-mcp [args...]    MCP qualification for core/SOLL surfaces
  benchmark-vector-token-matrix [args...] Run indexer-only token-cap throughput matrix (cold or warm)
  mcp-call [args...]       Direct MCP HTTP caller for list/call operations against the selected instance
  release-preflight [args...] Verify tracked-clean build/manifests prerequisites before release actions
  create-release-manifest [args...] Create canonical release manifest for promotion
  promote-live-safe [args...] One-shot safe live promotion: build, preflight, manifest, promote, qualify
  promote-live [args...]   Promote a qualified manifest to the live install state
  rollback-live [args...]  Roll back live install state to a prior manifest
  seed-dev-from-live [args...] Refresh the dev graph root from the live graph root
  sync-codex-mcp-config [args...] Print or refresh Codex MCP config with advertised Axon endpoints
  check-project-identity   Fail if legacy project identity terms reappear in active surfaces
  soll-import [args...]    SOLL import tool via MCP (md/json/ndjson/yaml)
  work-plan [args...]      SOLL read-only work plan tool
  resume-vectorization [args...] Requeue missing chunk vectorization from graph-ready files
  migrate-ignore [args...] Migrate .axonignore patterns to .gitignore (dry-run by default)
  reindex-project [args...] Reindex one project with before/after noise evaluation
  publish-memgraph [args...] Publish human-only IST/SOLL graph projection as versioned Parquet
  memgraph [args...]         Manage human-only Memgraph projection runtime/import

Examples:
  ./scripts/axon-live status
  ./scripts/axon-dev start --indexer-full
  ./scripts/axon --instance live status
  ./scripts/axon --instance dev start --indexer-full
  ./scripts/axon setup
  ./scripts/axon setup-tensorrt --precheck-only
  ./scripts/axon setup-tensorrt --qualify --max-vram-used-mb 2048 --tensorrt-workspace-mb 1024
  ./scripts/axon start --brain-only
  ./scripts/axon start --indexer-graph
  ./scripts/axon stop --hard
  ./scripts/axon restart --brain-only
  ./scripts/axon status
  ./scripts/axon --instance dev start --indexer-full --tensorrt
  ./scripts/axon benchmark-vector-token-matrix --tokens 4096,8192,16384 --duration 20 --interval 5
  ./scripts/axon benchmark-vector-token-matrix --mode warm --tokens 4096,8192,16384 --duration 20 --interval 5 --warmup-timeout 120
  ./scripts/axon qualify --profile demo --mode indexer_graph
  ./scripts/axon qualify --profile full --mode indexer_full --duration 120 --interval 5 --enforce-gate
  ./scripts/axon qualify --profile smoke --compare brain_only,indexer_graph
  ./scripts/axon --instance live qualify --profile smoke --mode indexer_graph
  ./scripts/axon qualify-mcp --surface core --checks quality,latency --mode steady-state --project AXO
  ./scripts/axon --instance live mcp-call list
  ./scripts/axon --instance live mcp-call call status --args '{"mode":"brief"}' --format text
  ./scripts/axon --instance live mcp-call call help --args '{"tool":"soll_apply_plan"}' --format data
  ./scripts/axon --instance live mcp-call call soll_apply_plan --args-file /tmp/soll-plan.json --format json
  ./scripts/axon release-preflight
  ./scripts/axon create-release-manifest --state qualified
  ./scripts/axon promote-live-safe --project AXO
  ./scripts/axon promote-live --manifest .axon/releases/candidates/v0.8.0-abc.json
  ./scripts/axon rollback-live --manifest .axon/live-release/history/live-20260418T120000Z.json
  ./scripts/axon seed-dev-from-live
  ./scripts/axon sync-codex-mcp-config
  ./scripts/axon sync-codex-mcp-config --apply
  ./scripts/axon check-project-identity
  ./scripts/axon soll-import --input docs/vision/SOLL_EXPORT_2026-04-04.md --format md
  ./scripts/axon soll-import --input /tmp/soll_payload.json --project AXO --author codex --dry-run
  ./scripts/axon work-plan --project AXO
  ./scripts/axon work-plan --project AXO --json
  ./scripts/axon resume-vectorization
  ./scripts/axon migrate-ignore --root "$(cd .. && pwd)" --apply
  ./scripts/axon reindex-project --project BookingSystem --wait-seconds 180
  ./scripts/axon publish-memgraph
  ./scripts/axon memgraph build-import --publication-dir .axon/memgraph/publications/pub-...
  ./scripts/axon memgraph smoke-queries
USAGE
}

instance_kind=""
explicit_instance=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --instance)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --instance" >&2
        exit 1
      fi
      instance_kind="$2"
      explicit_instance=1
      shift 2
      ;;
    --instance=*)
      instance_kind="${1#*=}"
      explicit_instance=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [[ -n "$instance_kind" ]]; then
  export AXON_INSTANCE_KIND="$instance_kind"
fi
axon_resolve_instance "$ROOT_DIR" "$(basename "$ROOT_DIR")"

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
  usage
  exit 1
fi
shift || true

if [[ "$cmd" == "qualify" && "$explicit_instance" -eq 0 ]]; then
  export AXON_INSTANCE_KIND="dev"
  axon_resolve_instance "$ROOT_DIR" "$(basename "$ROOT_DIR")"
fi

maybe_with_url() {
  local url="$1"
  shift
  for arg in "$@"; do
    if [[ "$arg" == "--url" || "$arg" == --url=* ]]; then
      printf '%s\0' "$@"
      return 0
    fi
  done
  printf '%s\0' --url "$url" "$@"
}

split_restart_args() {
  local stop_file="$1"
  local start_file="$2"
  shift 2

  : > "$stop_file"
  : > "$start_file"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --hard|--verify)
        printf '%s\n' "$1" >> "$stop_file"
        ;;
      *)
        printf '%s\n' "$1" >> "$start_file"
        ;;
    esac
    shift
  done
}

case "$cmd" in
  setup)
    exec bash "$SCRIPT_DIR/setup.sh" "$@"
    ;;
  setup-tensorrt)
    exec bash "$SCRIPT_DIR/setup-tensorrt.sh" "$@"
    ;;
  start)
    exec bash "$SCRIPT_DIR/start.sh" "$@"
    ;;
  stop)
    exec bash "$SCRIPT_DIR/stop.sh" "$@"
    ;;
  restart)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat <<'EOF'
Usage: ./scripts/axon [--instance live|dev] restart [stop options] [start mode options]

Stop options:
  --hard
  --verify

Start mode options:
  --brain-only
  --indexer-graph
  --indexer-vector
  --indexer-full
  --tensorrt
  --no-dashboard
  --skip-mcp-tests
  --skip-elixir-prewarm
EOF
      exit 0
    fi
    stop_args_file="$(mktemp)"
    start_args_file="$(mktemp)"
    trap 'rm -f "$stop_args_file" "$start_args_file"' EXIT
    split_restart_args "$stop_args_file" "$start_args_file" "$@"
    mapfile -t stop_args < "$stop_args_file"
    mapfile -t start_args < "$start_args_file"
    bash "$SCRIPT_DIR/stop.sh" "${stop_args[@]}"
    exec bash "$SCRIPT_DIR/start.sh" "${start_args[@]}"
    ;;
  status)
    exec bash "$SCRIPT_DIR/status.sh" "$@"
    ;;
  benchmark-vector-token-matrix)
    exec bash "$SCRIPT_DIR/benchmark-vector-token-matrix.sh" "$@"
    ;;
  qualify)
    exec python3 "$SCRIPT_DIR/qualify_runtime.py" "$@"
    ;;
  qualify-mcp)
    mapfile -d '' forwarded < <(maybe_with_url "$AXON_MCP_URL" "$@")
    exec python3 "$SCRIPT_DIR/qualify_mcp.py" "${forwarded[@]}"
    ;;
  mcp-call)
    exec env AXON_MCP_URL="$AXON_MCP_URL" python3 "$SCRIPT_DIR/mcp_call.py" "$@"
    ;;
  release-preflight)
    exec bash "$SCRIPT_DIR/release/preflight.sh" "$@"
    ;;
  create-release-manifest)
    exec python3 "$SCRIPT_DIR/release/create_manifest.py" "$@"
    ;;
  promote-live-safe)
    exec bash "$SCRIPT_DIR/release/promote_live_safe.sh" "$@"
    ;;
  promote-live)
    exec bash "$SCRIPT_DIR/release/promote_live.sh" "$@"
    ;;
  rollback-live)
    exec bash "$SCRIPT_DIR/release/rollback_live.sh" "$@"
    ;;
  seed-dev-from-live)
    exec bash "$SCRIPT_DIR/seed-dev-from-live.sh" "$@"
    ;;
  sync-codex-mcp-config)
    exec bash "$SCRIPT_DIR/sync-codex-mcp-config.sh" "$@"
    ;;
  check-project-identity)
    exec python3 "$SCRIPT_DIR/check_no_legacy_project_field.py"
    ;;
  soll-import)
    mapfile -d '' forwarded < <(maybe_with_url "$AXON_MCP_URL" "$@")
    exec python3 "$SCRIPT_DIR/soll_import.py" "${forwarded[@]}"
    ;;
  work-plan)
    mapfile -d '' forwarded < <(maybe_with_url "$AXON_MCP_URL" "$@")
    exec python3 "$SCRIPT_DIR/work_plan.py" "${forwarded[@]}"
    ;;
  resume-vectorization)
    exec python3 "$SCRIPT_DIR/resume_vectorization.py" "$@"
    ;;
  migrate-ignore)
    exec bash "$SCRIPT_DIR/migrate_axonignore_to_gitignore.sh" "$@"
    ;;
  reindex-project)
    exec python3 "$SCRIPT_DIR/reindex_project.py" "$@"
    ;;
  publish-memgraph)
    exec bash "$SCRIPT_DIR/publish-memgraph.sh" "$@"
    ;;
  memgraph)
    exec bash "$SCRIPT_DIR/memgraph-projection.sh" "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
