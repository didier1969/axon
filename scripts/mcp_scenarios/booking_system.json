{
  "project": "BKS",
  "steps": [
    {
      "name": "scenario.query_markdown_probe",
      "tool": "query",
      "args": {
        "query": "symbolic green CI"
      },
      "expect_contains": [
        "Task 9: Remove Symbolic Green From CI"
      ]
    },
    {
      "name": "scenario.query_config_probe",
      "tool": "query",
      "args": {
        "query": "Credo.Check.Refactor.CyclomaticComplexity"
      },
      "expect_contains": [
        "Type de resultat"
      ]
    },
    {
      "name": "scenario.project_status_after_queries",
      "tool": "project_status",
      "args": {
        "project_code": "BKS",
        "mode": "brief"
      },
      "expect_contains": [
        "Project Status",
        "BKS"
      ]
    }
  ]
}
