# =============================================================================
# Axon — DEV environment template (REQ-AXO-290, post-MIL-AXO-015 + REQ-AXO-289)
# =============================================================================
# Copy this file to `.env.local` or source it from your devenv shell. Every
# variable below has a real effect on system behaviour. The full classification
# of all 173 historical AXON_* env vars (KEEP / RENAME / DELETE-*) lives in
# `docs/working-notes/2026-05-12-req-axo-290-env-var-inventory.md`.
#
# Dev profile principle (PIL-AXO-006): dev yields under contention so live keeps
# responsiveness. Conservative budgets, CPU embedder by default, full indexer.
# =============================================================================

# --- Runtime topology -------------------------------------------------------
# Mode du process (CPT-AXO-053). Dev tourne IndexerFull = pipelines A + B actifs.
# Brain dev généralement OFF (le brain live sert toutes les requêtes MCP).
AXON_RUNTIME_MODE=indexer_full
AXON_INSTANCE_KIND=dev
# Gate PG indexer — restera tant que MIL-AXO-015 P3 slice 3h n'est pas
# définitivement validé. Sera retiré en REQ-AXO-289 slice S8.
AXON_INDEXER_PG_OPT_IN=1
AXON_DASHBOARD_ENABLED=0

# --- Database ---------------------------------------------------------------
AXON_DB_BACKEND=postgres
AXON_DEV_DATABASE_URL=postgres://axon@127.0.0.1:44144/axon_dev
# Pool size deadpool. Dev = 8 (1 par worker du plus gros pool — A2).
AXON_PG_POOL_SIZE=8

# --- Streaming pipeline v2 — per-stage workers (CPT-AXO-054) ----------------
# Pipeline A (graphe) — priorité vitesse, doit terminer avant que B suive.
AXON_A1_WORKERS=2     # I/O bound : lecture fichier + hash
AXON_A2_WORKERS=4     # CPU bound : tree-sitter parse
AXON_A3_WORKERS=1     # PG UPSERT Symbol + Chunk + AGE + IndexedFile
# Pipeline B (vectorisation) — rythmé par GPU.
AXON_B1_WORKERS=2     # PG read Chunk + assemblage seq-bucket
AXON_B2_WORKERS=1     # GPU embedder (1 par GPU physique)
AXON_B3_WORKERS=1     # PG UPSERT ChunkEmbedding
# Capacité des channels mpsc.
AXON_PIPELINE_INTERNAL_CHANNEL_CAP=1024
AXON_PIPELINE_A3_TO_B1_BUFFER_CAP=10000
AXON_B1_COLDSTART_BATCH_SIZE=256

# --- Vectorization (REQ-AXO-262 + REQ-AXO-272) ------------------------------
# Dev = CPU par défaut (libère le GPU pour live). Override `--gpu-backend
# tensorrt` au bench si besoin.
AXON_EMBEDDING_PROVIDER=cpu
AXON_EMBEDDING_BATCH_SIZE=64
# Buckets de longueur de séquence (REQ-AXO-262). Comma-separated tokens.
AXON_EMBEDDER_SEQ_BUCKETS=128,256,384,512
AXON_TARGET_CHUNK_TOKENS=480
AXON_CHUNK_OVERLAP_TOKENS=64

# --- Resource governance (PIL-AXO-006) --------------------------------------
AXON_RESOURCE_PRIORITY=best_effort
AXON_BACKGROUND_BUDGET_CLASS=conservative
AXON_GPU_ACCESS_POLICY=avoid
AXON_WATCHER_POLICY=bounded
AXON_MEMORY_LIMIT_GB=8
# VRAM budget conservatif laptop (avoid GPU profile mais peut être réquisitionné).
AXON_CUDA_MEMORY_LIMIT_MB=4000
AXON_CUDA_MEMORY_SOFT_LIMIT_MB=3500

# --- Scope ------------------------------------------------------------------
AXON_PROJECTS_ROOT=/home/dstadel/projects
AXON_WATCH_DIR=/home/dstadel/projects

# --- Observability (en mémoire, exportable à la demande) --------------------
# Si défini : per-stage metrics CSV écrit toutes les 1s. Vide = pas d'export.
# AXON_METRICS_EXPORT_CSV=/tmp/axon-dev-metrics.csv
# Si défini : Prometheus scrape endpoint.
# AXON_METRICS_EXPORT_PROMETHEUS_PORT=9090

# --- TensorRT cache (utile si on bascule sur --gpu-backend tensorrt) --------
AXON_TENSORRT_CACHE_DIR=/home/dstadel/projects/axon/.axon/trt-engine-cache-dev
# Profile shapes (REQ-AXO-262) — séparés par virgule, format batch_size:seq_len.
AXON_TRT_PROFILE_MIN_SHAPES=1:128
AXON_TRT_PROFILE_OPT_SHAPES=64:256
AXON_TRT_PROFILE_MAX_SHAPES=128:512
